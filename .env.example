# Environment Variables Template
# Copy this to .env and fill in your values

# Chainlink CRE Configuration
CRE_ETH_PRIVATE_KEY=your_private_key_here
CRE_TARGET=staging-settings

# Google Gemini API (for AI rephrasing)
GEMINI_API_KEY_VAR=your_gemini_api_key_here

# Network Configuration
RPC_URL=https://sepolia.infura.io/v3/your_infura_key_here

# Contract Addresses (update after deployment)
MARKET_ADDRESS=0x0000000000000000000000000000000000000000

# API Keys (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
